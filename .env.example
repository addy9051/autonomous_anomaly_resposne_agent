# ═══════════════════════════════════════════════════════════════
#  Payment Reliability Agent System — Environment Variables
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── LLM Providers ────────────────────────────────────────────
# At least one is required. OpenAI recommended for quickstart.
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Google Cloud / Vertex AI (optional, for Gemini + embeddings)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json  # Not recommended. Use 'gcloud auth application-default login' instead.
GOOGLE_PROJECT_ID=amex-autonomouse-expense-ai
GOOGLE_REGION=us-central1
VERTEX_AI_MODEL=gemini-2.5-flash-lite

# Anthropic (optional, for Claude Haiku classification)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Cohere (optional, enables cross-encoder reranking in RAG pipeline)
COHERE_API_KEY=your-cohere-api-key-here

# ─── LangSmith Observability ─────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls_your-langsmith-key-here
LANGCHAIN_PROJECT=anomaly-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Data & Infrastructure ────────────────────────────────────
# PostgreSQL (local or cloud)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_kb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=agent_secret_2024

# Supabase (Cloud Alternative)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# ─── Observability & Monitoring ────────────────────────────────
# Langchain (for LangSmith tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=anomaly-agent

# Langfuse (for LLM observability)
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_HOST=http://localhost:3001

# ─── Third-Party Integrations ──────────────────────────────────
# Slack (Recommended: Use Channel IDs instead of names)
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxx
SLACK_ALERT_CHANNEL=C0XXXXXXX   # Channel ID for alerts
SLACK_APPROVAL_CHANNEL=C0YYYYYY # Channel ID for approvals

# PagerDuty
PAGERDUTY_API_KEY=xxxxxxxxxxxxxxxxxxxx
PAGERDUTY_SERVICE_ID=XXXXXXX

# N8n
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Grafana (Use modern Service Account tokens)
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=glsa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Prometheus ──────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090

GRAFANA_API_KEY=your-grafana-api-key

# ─── OpenTelemetry ───────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=anomaly-response-agent

# ─── Agent Configuration ─────────────────────────────────────
ANOMALY_CONFIDENCE_THRESHOLD=0.75
MAX_TOKENS_PER_INCIDENT=50000
MONITORING_AGENT_MODEL=gpt-4o-mini
DIAGNOSIS_AGENT_MODEL=gpt-4o
ACTION_AGENT_MODEL=gpt-4o
FEEDBACK_AGENT_MODEL=gpt-4o-mini

# ─── Application ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
