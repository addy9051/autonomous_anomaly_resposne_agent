# ═══════════════════════════════════════════════════════════════
#  Payment Reliability Agent System — Environment Variables
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── LLM Providers ────────────────────────────────────────────
# At least one is required. OpenAI recommended for quickstart.
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Google Cloud / Vertex AI (optional, for Gemini + embeddings)
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_REGION=us-central1
VERTEX_AI_MODEL=gemini-1.5-pro

# Anthropic (optional, for Claude Haiku classification)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ─── LangSmith Observability ─────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls_your-langsmith-key-here
LANGCHAIN_PROJECT=anomaly-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ─── Supabase (pgvector for RAG) ─────────────────────────────
# Use either Supabase Cloud or local PostgreSQL
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_DB_URL=postgresql://postgres:password@localhost:5432/agent_kb

# ─── Local PostgreSQL (Docker Compose) ────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_kb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=agent_secret_2024

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# ─── Slack Integration ────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_ALERT_CHANNEL=#incident-alerts
SLACK_APPROVAL_CHANNEL=#sre-approvals

# ─── PagerDuty (optional) ────────────────────────────────────
PAGERDUTY_API_KEY=your-pagerduty-api-key
PAGERDUTY_SERVICE_ID=your-service-id

# ─── N8n Automation ──────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key

# ─── Prometheus ──────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090

# ─── Grafana ─────────────────────────────────────────────────
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=your-grafana-api-key

# ─── OpenTelemetry ───────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=anomaly-response-agent

# ─── Agent Configuration ─────────────────────────────────────
ANOMALY_CONFIDENCE_THRESHOLD=0.75
MAX_TOKENS_PER_INCIDENT=50000
MONITORING_AGENT_MODEL=gpt-4o-mini
DIAGNOSIS_AGENT_MODEL=gpt-4o
ACTION_AGENT_MODEL=gpt-4o
FEEDBACK_AGENT_MODEL=gpt-4o-mini

# ─── Application ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
